# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Azure specific
.az/

# Sensitive vars
*.tfvars
!example.tfvars

# Backend config gerado em runtime (contém nome do Storage Account)
backend.hcl

# Outputs gerados após terraform apply (contém valores reais de infra)
outputs.json

# Logs de deploy
.deploy-logs/